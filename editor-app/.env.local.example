# Secret utilisé pour signer le JWT local (indépendant du token Region Lovers).
# Générer une longue chaîne aléatoire, par exemple : openssl rand -hex 32
JWT_SECRET=change-me-to-a-long-random-string

# Chaîne de connexion MongoDB Atlas (cluster gratuit suffisant).
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=landing_guide_editor
